# Copy to .env (or .env.local) and fill in. Never commit real secrets — .env* is gitignored.

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Cloudflare R2 (profile photos & resumes) -------------------------------
# See docs/R2_SETUP.md for how to obtain these. Server-only — do NOT prefix with
# NEXT_PUBLIC_ (these must never reach the browser).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=careerlaunchpad-profiles
# Public domain bound to the bucket for serving photos (e.g. https://cdn.example.com
# or the bucket's r2.dev URL). Leave blank to keep everything private/presigned.
R2_PUBLIC_BASE_URL=

# --- Email (transactional notifications via SMTP, e.g. Zoho Mail) -----------
# Generic SMTP. For Zoho: host smtppro.zoho.in, port 465 (SSL) or 587 (STARTTLS),
# SMTP_USER = the full mailbox address, SMTP_PASSWORD = a Zoho app-specific
# password (generate one with 2FA on the mailbox). Leave SMTP_* blank to keep
# logging emails to the console instead of sending. Server-only — never NEXT_PUBLIC_.
SMTP_HOST=smtppro.zoho.in
SMTP_PORT=465
SMTP_USER=noreply@careerlaunchpad.ai
SMTP_PASSWORD=
# Visible From. MAIL_FROM_ADDRESS must be a mailbox/alias SMTP_USER may send as
# (defaults to SMTP_USER if blank). MAIL_FROM_NAME is the friendly display name.
MAIL_FROM_ADDRESS=noreply@careerlaunchpad.ai
MAIL_FROM_NAME=CareerLaunchPad
