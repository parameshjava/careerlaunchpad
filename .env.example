# Copy to .env (or .env.local) and fill in. Never commit real secrets — .env* is gitignored.

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Cloudflare R2 (profile photos & resumes) -------------------------------
# See docs/R2_SETUP.md for how to obtain these. Server-only — do NOT prefix with
# NEXT_PUBLIC_ (these must never reach the browser).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=careerlaunchpad-profiles
# Public domain bound to the bucket for serving photos (e.g. https://cdn.example.com
# or the bucket's r2.dev URL). Leave blank to keep everything private/presigned.
R2_PUBLIC_BASE_URL=

# --- Email (invite notifications via Gmail SMTP) ----------------------------
# Personal Gmail account + 16-char App Password (requires 2-Step Verification:
# myaccount.google.com/apppasswords). Leave both blank to keep logging invites
# to the console instead of sending real email. Server-only — never NEXT_PUBLIC_.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Optional friendly From name (the address is always GMAIL_USER).
MAIL_FROM_NAME=CareerLaunchPad
